# LLM API Keys - set at least one provider
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Local/dev LLM safety guardrails (per turn bucket; set to 0 to disable)
LLM_BUDGET_WINDOW_MS=900000
LLM_BUDGET_MAX_REQUESTS=10
LLM_BUDGET_MAX_PROJECTED_TOKENS=500000
LLM_BUDGET_BUCKET_TTL_MS=3600000

# Email notifications (optional - logs to console if not set)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
APP_URL=http://localhost:5173
